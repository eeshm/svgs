{
  "$schema": "https://opencode.ai/config.json",
  "username": "Eesh",
  "model": "github-copilot/gpt-5.3-codex",
  "enabled_providers": [
    "github-copilot"
  ],
  "default_agent": "build",
  "share": "manual",
  "autoupdate": "notify",
  "instructions": [
    "AGENTS.md"
  ],
  "watcher": {
    "ignore": [
      "**/node_modules/**",
      "**/.git/**",
      "**/dist/**",
      "**/build/**",
      "**/.next/**",
      "**/coverage/**"
    ]
  }
}
